# Python
__pycache__/
src/wc2026/__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/

# Virtual env
.venv/
venv/
env/

# Raw downloads are large + externally sourced — fetched via the data adapters.
data/raw/*
data/interim/*
!data/raw/.gitkeep
!data/interim/.gitkeep

# Processed results: KEEP the small result tables (committed deliverables),
# ignore everything else regenerable.
data/processed/*
!data/processed/.gitkeep
!data/processed/*.csv

# Artifacts: KEEP the charts (small, showcase), IGNORE the heavy regenerable
# posterior files (~7.5 MB each).
artifacts/*
!artifacts/.gitkeep
!artifacts/*.png

# Notebooks / tooling
.ipynb_checkpoints/
.pytest_cache/
.ruff_cache/
.DS_Store

.pytest_cache
